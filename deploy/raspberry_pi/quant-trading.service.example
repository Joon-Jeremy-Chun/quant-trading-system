[Unit]
Description=Quant Trading Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/quant-trading-system
EnvironmentFile=/home/pi/quant-trading-system/deploy/raspberry_pi/quant-trading.env
ExecStart=/home/pi/quant-trading-system/.venv/bin/python /home/pi/quant-trading-system/jobs/trade_job.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
