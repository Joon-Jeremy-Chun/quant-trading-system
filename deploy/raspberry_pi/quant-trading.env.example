APCA_API_KEY_ID=replace_with_your_key
APCA_API_SECRET_KEY=replace_with_your_secret

# Optional custom variables for future strategy scripts.
# SYMBOL=GLD
# MODE=paper
LIVE_SYMBOLS=GLD,BRK-B
LIVE_MODEL_MANIFEST=models/live/latest_model_manifest.json
REQUIRE_LIVE_MODEL_MANIFEST=false
ALPACA_DRY_RUN=true
ALPACA_DRY_RUN_WRITES_LIVE_BOOK=false
ALPACA_MARKET_DATA_FEED=iex
ALPACA_BASE_POSITION_QTY=10
ALPACA_MIN_WEIGHT_TO_OPEN=0.15
ALPACA_MIN_REBALANCE_QTY=1
MAX_SIGNAL_AGE_DAYS=5
MAX_DATASET_STALENESS_DAYS=5
MAX_MODEL_AGE_DAYS=540
BLOCK_ON_STALE_MODEL=false
EMAIL_ALERT_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=replace_with_your_email_username
SMTP_PASSWORD=replace_with_your_email_app_password
ALERT_EMAIL_FROM=replace_with_sender@example.com
ALERT_EMAIL_TO=replace_with_receiver@example.com
