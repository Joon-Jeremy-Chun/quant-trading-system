[Unit]
Description=GLD/BRK-B daily live pipeline (pull -> update data -> build signal -> order -> email)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=pi
WorkingDirectory=/home/pi/quant-trading-system
EnvironmentFile=/home/pi/quant-trading-system/deploy/raspberry_pi/quant-trading.env
ExecStart=/home/pi/quant-trading-system/.venv/bin/python /home/pi/quant-trading-system/jobs/gld_daily_pipeline.py --build-signal --symbols GLD,BRK-B
